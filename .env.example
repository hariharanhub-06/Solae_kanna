# ---- ENVIRONMENT VARIABLES TEMPLATE ----
# Copy this file to ".env" for local development, and set the same variables
# in your Vercel Project Settings > Environment Variables for production.

# DATABASE (Neon Postgres) ---------------------------------------------------
# From your Neon project dashboard > Connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ADMIN LOGIN ----------------------------------------------------------------
# Admin accounts are stored in the database (see prisma/seed.mjs for the
# super-admin bootstrap account). AUTH_SECRET signs the login cookie.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_HEX"

# IMAGEKIT (image uploads) ---------------------------------------------------
# From https://imagekit.io dashboard > Developer options.
IMAGEKIT_PUBLIC_KEY="public_xxxxxxxxxxxxxxxxxxxxxxxx"
IMAGEKIT_PRIVATE_KEY="private_xxxxxxxxxxxxxxxxxxxxxxxx"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_imagekit_id"

# SITE URL (optional, for correct sitemap/SEO absolute URLs in production) ----
# SITE_URL="https://your-domain.com"
