{
  "name": "solar-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node --env-file=.env prisma/seed.mjs",
    "db:reset": "prisma db push --force-reset && node --env-file=.env prisma/seed.mjs"
  },
  "prisma": {
    "seed": "node --env-file=.env prisma/seed.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "imagekit": "^6.0.0",
    "jose": "^5.9.6",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.15",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
